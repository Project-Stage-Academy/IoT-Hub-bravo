      "name": "Living Room High Temperature Alert",
      "description": "Trigger when temperature exceeds 27.5°C for more than 10 minutes",
      "condition": {
        "type": "threshold",
        "value": 27.5,
        "operator": ">",
        "duration_minutes": 10
      },
      "action": {
        "webhook": {
          "url": "https://webhook.site/a1b2c3d4-0001-4a5b-8c9d-living-room-temp",
          "enabled": true
        },
        "notification": {
          "channel": "email",
          "enabled": true,
          "message": "High temperature in {device_name}: {value}°C"
        }
      },
      "is_active": true,
      "device_metric": 1
    }
  },
